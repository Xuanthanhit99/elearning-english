enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum PlacementMethod {
  TEST
  CERTIFICATE
  MANUAL
}

enum PlacementStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LearningSkill {
  VOCABULARY
  GRAMMAR
  LISTENING
  READING
  SPEAKING
  WRITING
}

model UserPlacement {
  id           String          @id @default(cuid())
  userId       String          @unique
  method       PlacementMethod
  status       PlacementStatus @default(COMPLETED)
  overallLevel CefrLevel
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillLevels  UserSkillLevel[]
}

model UserSkillLevel {
  id          String        @id @default(cuid())
  userId      String
  placementId String?
  skill       LearningSkill
  level       CefrLevel
  score       Float?
  source      PlacementMethod
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  placement   UserPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)

  @@unique([userId, skill])
  @@index([userId])
}
