// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENT
  FIXED
}

model User {
  id         String     @id @default(uuid())
  fullname   String
  email      String     @unique
  password   String
  role       UserRole   @default(STUDENT)
  avatar     String?
  status     UserStatus @default(ACTIVE)
  provider   String?
  providerId String?
  courses    Course[]

  enrollments Enrollment[]

  lessonProgress LessonProgress[]

  quizResults QuizResult[]

  certificates Certificate[]

  notifications Notification[]

  orders Order[]

  review Review[]

  withdrawRequests WithdrawRequest[]

  speakingResults SpeakingResult[]

  wordHistories UserWordHistory[]

  writingSubmissions WritingSubmission[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String       @id @default(uuid())
  teacherId   String
  title       String
  slug        String       @unique
  description String?
  thumbnail   String?
  level       String
  price       Int          @default(0)
  status      CourseStatus @default(DRAFT)

  teacher  User      @relation(fields: [teacherId], references: [id])
  sections Section[]

  enrollments Enrollment[]

  lessonProgress LessonProgress[]

  certificates Certificate[]

  orders Order[]

  review Review[]

  landing CourseLanding?

  page CoursePage?

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id       String @id @default(uuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id        String  @id @default(uuid())
  sectionId String
  title     String
  content   String?
  videoUrl  String?
  duration  Int?
  order     Int     @default(0)
  isPreview Boolean @default(false)

  section Section @relation(fields: [sectionId], references: [id])

  lessonProgress LessonProgress[]

  quizzes Quiz[]

  quizResults QuizResult[]

  speakingResults   SpeakingResult[]
  speakingExercises SpeakingExercise[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  courseId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model CourseLanding {
  id         String  @id @default(uuid())
  courseId   String  @unique
  headline   String?
  subTitle   String?
  introVideo String?
  benefits   Json?
  faq        Json?

  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoursePage {
  id       String @id @default(uuid())
  courseId String @unique
  blocks   Json

  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quiz {
  id       String @id @default(uuid())
  lessonId String
  question String
  options  Json
  answer   String

  lesson Lesson @relation(fields: [lessonId], references: [id])

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizResult {
  id       String @id @default(uuid())
  userId   String
  lessonId String
  score    Int
  total    Int
  correct  Int
  answers  Json

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model Certificate {
  id       String @id @default(uuid())
  userId   String
  courseId String
  code     String @unique

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Order {
  id       String @id @default(uuid())
  userId   String
  courseId String

  amount         Int
  originalAmount Int?
  discountAmount Int     @default(0)
  couponCode     String?

  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  updatedAt DateTime @updatedAt
}

model Review {
  id       String  @id @default(uuid())
  userId   String
  courseId String
  rating   Int
  comment  String?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model WithdrawRequest {
  id        String         @id @default(uuid())
  teacherId String
  amount    Int
  status    WithdrawStatus @default(PENDING)
  note      String?

  teacher User @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType // PERCENT | FIXED
  discountValue Int
  maxUses       Int?
  usedCount     Int          @default(0)
  expiredAt     DateTime?
  isActive      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String  @id @default(uuid())
  userId  String
  title   String
  message String
  isRead  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SpeakingExercise {
  id       String @id @default(uuid())
  lessonId String

  title  String
  prompt String

  lesson  Lesson           @relation(fields: [lessonId], references: [id])
  results SpeakingResult[]

  createdAt DateTime @default(now())
}

model SpeakingResult {
  id String @id @default(uuid())

  userId     String
  exerciseId String
  lessonId   String

  audioUrl   String?
  transcript String?
  score      Int?
  feedback   Json?

  createdAt DateTime         @default(now())
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  exercise  SpeakingExercise @relation(fields: [exerciseId], references: [id])
}

model Word {
  id               String   @id @default(uuid())
  word             String
  sourceLanguage   String
  targetLanguage   String
  level            String?
  ipa              String?
  audio            String?
  partOfSpeech     String?
  definition       String?
  mainMeaning      String?
  shortExplanation String?
  synonyms         Json?
  phrases          Json?
  examples         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  histories        UserWordHistory[]

  @@unique([word, sourceLanguage, targetLanguage, level])
}

model UserWordHistory {
  id        String   @id @default(uuid())
  userId    String
  wordId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  word      Word     @relation(fields: [wordId], references: [id])

  @@unique([userId, wordId])
}

model WritingSubmission {
  id               String   @id @default(uuid())
  userId           String?
  originalText     String
  detectedLanguage String?
  style            String?
  level            String   @default("Beginner")

  score            Int?
  grammarScore     Int?
  vocabularyScore  Int?
  clarityScore     Int?
  meaningScore     Int?
  summary String?
  corrections      Json?
  suggestedVersion String?
  phrases          Json?
  learningTips     Json?
  miuNote          String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User?    @relation(fields: [userId], references: [id])
}
