  fileUrl          String
  originalFileName String?
  mimeType         String?

  certificateNumber String?
  candidateName     String?
  organization      String?

  overallScore   Float?
  listeningScore Float?
  readingScore   Float?
  speakingScore  Float?
  writingScore   Float?

  mappedOverallLevel CefrLevel?
  confidence         Float?
  issuedAt           DateTime?
  expiresAt          DateTime?

  extractedData       Json?
  verificationMessage String?

  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
}

