// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ModeType {
  LEVEL_BASED
  ADAPTIVE
}

enum CommunityPostType {
  POST
  SPEAKING
  WRITING
  WORD
  QUESTION
  IMAGE
}

enum CommunityVisibility {
  PUBLIC
  FRIENDS
  STUDY_GROUP
  ONLY_ME
}

enum MissionType {
  DAILY
  WEEKLY
  ACHIEVEMENT
}

enum MissionAction {
  STUDY_LESSON
  LEARN_WORD
  COMPLETE_QUIZ
  CHECK_WRITING
  PRACTIVE_PRONUNCIATION
  LOGIN
}

enum WordSource {
  SEED
  DICTIONARY_API
  GEMINI
  ADMIN
}

enum WordProgressStatus {
  NEW
  LEARNING
  REVIEW
  KNOWN
  MASTERED
}

enum VocabularyQuestionType {
  MULTIPLE_CHOICE
  WRITE_MEANING
  WRITE_WORD
  WRITE_SENTENCE
}

enum WeeklyTestStatus {
  LOCKED
  AVAILABLE
  PASSED
  FAILED
}

enum DailyVocabularyStatus {
  LOCKED
  AVAILABLE
  COMPLETED
  MISSED
}

enum PlacementTestStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum PlacementQuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  LISTENING
  READING
  SPEAKING
  WRITING
}

model User {
  id       String   @id @default(uuid())
  fullname String
  email    String   @unique
  password String
  role     UserRole @default(STUDENT)
  avatar   String?

  username String? @unique
  bio      String?
  goal     String?
  level    Int     @default(1)
  xp       Int     @default(0)
  isPro    Boolean @default(false)

  interests String[] @default([])

  status       UserStatus @default(ACTIVE)
  provider     String?
  providerId   String?
  courses      Course[]
  phone        String?
  englishLevel String?    @default("Beginner")
  learningGoal String?    @default("General English")

  enrollments Enrollment[]

  lessonProgress LessonProgress[]

  quizResults QuizResult[]

  certificates Certificate[]

  notifications Notification[]

  orders Order[]

  review Review[]

  withdrawRequests WithdrawRequest[]

  speakingResults SpeakingResult[]

  wordHistories UserWordHistory[]

  writingSubmissions WritingSubmission[]
  placementResults   PlacementResult[]

  petProfile PetProfile?
  petRewards PetReward[]

  listeningSession ListeningSession[]

  grammarLessonProgress GrammarLessonProgress[]
  grammarTopicProgress  GrammarTopicProgress[]
  grammarLessonNotes    GrammarLessonNote[]

  arenaProfile      ArenaProfile?
  arenaRooms        ArenaRoom[]
  arenaParticipants ArenaParticipant[]
  arenaRewards      ArenaRewardLog[]
  arenaAnswers      ArenaAnswer[]
  arenaQueue        ArenaQueue?
  arenaRoomEvents   ArenaRoomEvent[]

  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  communitySaves    CommunitySave[]

  pronunciationResult PronunciationResult[]

  missions UserMission[]

  placement               UserPlacement?
  skillLevels             UserSkillLevel[]
  placementProcessingJobs PlacementProcessingJob[]

  currentPlacementTestId String?
  currentPlacementTest   PlacementTest?  @relation("CurrentPlacementTest", fields: [currentPlacementTestId], references: [id], onDelete: SetNull)
  placementTests         PlacementTest[] @relation("UserPlacementTests")

  createAt                  DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  userLearningProfile       UserLearningProfile?
  userWordProgresses        UserWordProgress[]
  userWeeklyVocabularyPlans UserWeeklyVocabularyPlan[]
  weeklyVocabularyTests     WeeklyVocabularyTest[]
  vocabularyNotebookItems   UserVocabularyNotebook[]
  languageCertificates      UserLanguageCertificate[]
}

model Course {
  id          String       @id @default(uuid())
  teacherId   String
  title       String
  slug        String       @unique
  description String?
  thumbnail   String?
  level       String
  price       Int          @default(0)
  status      CourseStatus @default(DRAFT)

  teacher  User      @relation(fields: [teacherId], references: [id])
  sections Section[]

  enrollments Enrollment[]

  lessonProgress LessonProgress[]

  certificates Certificate[]

  orders Order[]

  review Review[]

  landing CourseLanding?

  page CoursePage?

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id       String @id @default(uuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id        String  @id @default(uuid())
  sectionId String
  title     String
  content   String?
  videoUrl  String?
  duration  Int?
  order     Int     @default(0)
  isPreview Boolean @default(false)

  section Section @relation(fields: [sectionId], references: [id])

  lessonProgress LessonProgress[]

  petRewards PetReward[]

  quizzes Quiz[]

  quizResults QuizResult[]

  speakingResults   SpeakingResult[]
  speakingExercises SpeakingExercise[]

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  courseId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model CourseLanding {
  id         String  @id @default(uuid())
  courseId   String  @unique
  headline   String?
  subTitle   String?
  introVideo String?
  benefits   Json?
  faq        Json?

  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoursePage {
  id       String @id @default(uuid())
  courseId String @unique
  blocks   Json

  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quiz {
  id       String @id @default(uuid())
  lessonId String
  question String
  options  Json
  answer   String

  lesson Lesson @relation(fields: [lessonId], references: [id])

  createAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizResult {
  id       String @id @default(uuid())
  userId   String
  lessonId String
  score    Int
  total    Int
  correct  Int
  answers  Json

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
}

model Certificate {
  id       String @id @default(uuid())
  userId   String
  courseId String
  code     String @unique

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Order {
  id       String @id @default(uuid())
  userId   String
  courseId String

  amount         Int
  originalAmount Int?
  discountAmount Int     @default(0)
  couponCode     String?

  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  updatedAt DateTime @updatedAt
}

model Review {
  id       String  @id @default(uuid())
  userId   String
  courseId String
  rating   Int
  comment  String?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model WithdrawRequest {
  id        String         @id @default(uuid())
  teacherId String
  amount    Int
  status    WithdrawStatus @default(PENDING)
  note      String?

  teacher User @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType // PERCENT | FIXED
  discountValue Int
  maxUses       Int?
  usedCount     Int          @default(0)
  expiredAt     DateTime?
  isActive      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String  @id @default(uuid())
  userId  String
  title   String
  message String
  isRead  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SpeakingExercise {
  id       String @id @default(uuid())
  lessonId String

  title  String
  prompt String

  lesson  Lesson           @relation(fields: [lessonId], references: [id])
  results SpeakingResult[]

  createdAt DateTime @default(now())
}

model SpeakingResult {
  id String @id @default(uuid())

  userId     String
  exerciseId String
  lessonId   String

  audioUrl   String?
  transcript String?
  score      Int?
  feedback   Json?

  createdAt DateTime         @default(now())
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  exercise  SpeakingExercise @relation(fields: [exerciseId], references: [id])
}

model Word {
  id           String   @id @default(uuid())
  word         String   @unique
  phonetic     String?
  audio        String?
  partOfSpeech String?
  meaningVi    String?
  meaningEn    String?
  example      String?
  synonyms     String[] @default([])
  antonyms     String[] @default([])

  level      String @default("A1")
  difficulty Int    @default(1)

  topicId String?
  topic   WordTopic? @relation(fields: [topicId], references: [id])

  source        WordSource @default(SEED)
  isAiGenerated Boolean    @default(false)
  needsReview   Boolean    @default(false)

  searchCount Int @default(0)

  histories                 UserWordHistory[]
  progress                  UserWordProgress[]
  dailyWords                UserDailyVocabularyWord[]
  weeklyVocabularyQuestions WeeklyVocabularyQuestion[]
  notebookItems             UserVocabularyNotebook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([topicId])
}

model UserWordHistory {
  id         String   @id @default(uuid())
  userId     String
  wordId     String
  keyword    String
  searchedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  word Word @relation(fields: [wordId], references: [id])

  @@index([userId])
  @@index([wordId])
}

model WritingSubmission {
  id               String  @id @default(uuid())
  userId           String?
  originalText     String
  detectedLanguage String?
  style            String?
  level            String  @default("Beginner")

  score            Int?
  grammarScore     Int?
  vocabularyScore  Int?
  clarityScore     Int?
  meaningScore     Int?
  summary          String?
  corrections      Json?
  suggestedVersion String?
  phrases          Json?
  learningTips     Json?
  miuNote          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model PlacementTest {
  id     String              @id @default(uuid())
  userId String
  mode   ModeType            @default(ADAPTIVE)
  status PlacementTestStatus @default(IN_PROGRESS)

  level   CefrLevel?
  score   Int        @default(0)
  total   Int        @default(0)
  correct Int        @default(0)

  answers Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User                    @relation("UserPlacementTests", fields: [userId], references: [id], onDelete: Cascade)
  questions     PlacementTestQuestion[]
  processingJob PlacementProcessingJob?
  result        PlacementResult?

  currentForUsers User[] @relation("CurrentPlacementTest")

  @@index([userId])
  @@index([status])
}

model PlacementTestQuestion {
  id         String @id @default(uuid())
  testId     String
  questionId String
  order      Int

  userAnswer String?
  isCorrect  Boolean?
  score      Float?
  aiFeedback Json?
  answeredAt DateTime?

  isFlagged    Boolean @default(false)
  isSkipped    Boolean @default(false)
  spentSeconds Int     @default(0)

  audioUrl    String?
  transcript  String?
  writingText String? @db.Text
  wordCount   Int?

  test     PlacementTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question PlacementQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([testId, questionId])
  @@unique([testId, order])
  @@index([testId])
}

model PlacementQuestion {
  id            String                @id @default(uuid())
  skill         LearningSkill
  level         CefrLevel
  type          PlacementQuestionType
  question      String
  options       Json?
  correctAnswer String?
  explanation   String?
  audioUrl      String?
  passage       String?
  order         Int                   @default(0)
  isActive      Boolean               @default(true)

  source        PlacementQuestionSource @default(SEED)
  aiModel       String?
  generationKey String?

  usageCount    Int                     @default(0)
  audioScript   String?                 @db.Text
  testQuestions PlacementTestQuestion[]
  questionHash  String?                 @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skill, level, type])
  @@index([skill, level])
  @@index([source])
  @@index([usageCount])
}

model PronunciationExercise {
  id          String   @id @default(uuid())
  title       String
  type        String   @default("sentence")
  level       String   @default("A2")
  text        String
  ipa         String?
  focusSounds Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results PronunciationResult[]
}

model PronunciationResult {
  id          String   @id @default(uuid())
  userId      String
  exerciseId  String
  audioUrl    String?
  score       Int
  clarity     Int
  stress      Int
  endingSound Int
  fluency     Int
  feedback    Json
  createdAt   DateTime @default(now())

  user     User                  @relation(fields: [userId], references: [id])
  exercise PronunciationExercise @relation(fields: [exerciseId], references: [id])
}

model PetProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  petType          String
  petName          String
  isChosen         Boolean   @default(false)
  chooseDeadline   DateTime?
  selectedAt       DateTime?
  randomAssigned   Boolean   @default(false)
  hp               Int       @default(100)
  energy           Int       @default(100)
  happiness        Int       @default(100)
  hunger           Int       @default(80)
  xp               Int       @default(0)
  coins            Int       @default(0)
  food             Int       @default(2)
  streak           Int       @default(0)
  bestStreak       Int       @default(0)
  completedLessons Int       @default(0)
  lastStudyDate    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PetReward {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String
  xp        Int      @default(30)
  coins     Int      @default(12)
  food      Int      @default(1)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

enum ArenaRoomStatus {
  WAITING
  PLAYING
  FINISHED
  CANCELLED
}

enum ArenaVisibility {
  PUBLIC
  PRIVATE
}

enum ArenaTeam {
  A
  B
}

model ArenaProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  mmr           Int       @default(1500)
  arenaPoint    Int       @default(1500)
  level         Int       @default(1)
  winCount      Int       @default(0)
  loseCount     Int       @default(0)
  winStreak     Int       @default(0)
  bestWinStreak Int       @default(0)
  arenaFood     Int       @default(0)
  gold          Int       @default(0)
  trophy        Int       @default(0)
  lastMatchAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ArenaRoom {
  id              String          @id @default(uuid())
  hostId          String
  name            String
  visibility      ArenaVisibility @default(PUBLIC)
  password        String?
  gameMode        String
  skill           String
  winCondition    String
  durationSec     Int?
  maxWrong        Int?
  targetCorrect   Int?
  bestOf          Int?
  difficulty      String
  topic           String
  teamSize        Int             @default(1)
  maxPlayers      Int             @default(2)
  voiceChat       Boolean         @default(false)
  emojiEnabled    Boolean         @default(true)
  pingEnabled     Boolean         @default(true)
  status          ArenaRoomStatus @default(WAITING)
  countdownEndsAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  host         User               @relation(fields: [hostId], references: [id])
  participants ArenaParticipant[]
  matches      ArenaMatch[]
  events       ArenaRoomEvent[]
}

model ArenaParticipant {
  id       String    @id @default(uuid())
  roomId   String
  userId   String
  team     ArenaTeam @default(A)
  score    Int       @default(0)
  correct  Int       @default(0)
  wrong    Int       @default(0)
  ready    Boolean   @default(false)
  joinedAt DateTime  @default(now())

  room ArenaRoom @relation(fields: [roomId], references: [id])
  user User      @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model ArenaMatch {
  id         String    @id @default(uuid())
  roomId     String
  winnerTeam String?
  result     Json?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  room      ArenaRoom        @relation(fields: [roomId], references: [id])
  rewards   ArenaRewardLog[]
  questions ArenaQuestion[]
  answers   ArenaAnswer[]
}

model ArenaRewardLog {
  id          String   @id @default(uuid())
  matchId     String
  userId      String
  isWinner    Boolean
  mmrBefore   Int
  mmrAfter    Int
  arenaDelta  Int
  foodDelta   Int
  goldDelta   Int
  trophyDelta Int      @default(0)
  createdAt   DateTime @default(now())

  match ArenaMatch @relation(fields: [matchId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
}

model ArenaQueue {
  id           String   @id @default(uuid())
  userId       String   @unique
  gameMode     String
  skill        String
  difficulty   String
  topic        String
  mmr          Int
  searchMinMmr Int
  searchMaxMmr Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ArenaRoomEvent {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  room ArenaRoom @relation(fields: [roomId], references: [id])
  user User      @relation(fields: [userId], references: [id])
}

model ArenaQuestion {
  id          String   @id @default(uuid())
  matchId     String
  order       Int
  type        String
  skill       String
  prompt      String
  options     Json?
  answer      String
  explanation String?
  mediaUrl    String?
  points      Int      @default(10)
  createdAt   DateTime @default(now())

  match   ArenaMatch    @relation(fields: [matchId], references: [id])
  answers ArenaAnswer[]

  @@unique([matchId, order])
}

model ArenaAnswer {
  id         String   @id @default(uuid())
  matchId    String
  questionId String
  userId     String
  answer     String
  isCorrect  Boolean
  points     Int      @default(0)
  answeredAt DateTime @default(now())

  match    ArenaMatch    @relation(fields: [matchId], references: [id])
  question ArenaQuestion @relation(fields: [questionId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@unique([questionId, userId])
}

model CommunityPost {
  id         String              @id @default(uuid())
  userId     String
  type       CommunityPostType
  visibility CommunityVisibility @default(PUBLIC)

  title    String?
  content  String?
  hashtags String[] @default([])

  audioUrl String?
  imageUrl String?

  aiScore    Int?
  grammar    Int?
  vocabulary Int?
  natural    Int?
  accuracy   Int?

  word      String?
  ipa       String?
  meaning   String?
  example   String?
  memoryTip String?

  allowListen  Boolean @default(false)
  wantFeedback Boolean @default(false)

  user     User               @relation(fields: [userId], references: [id])
  comments CommunityComment[]
  likes    CommunityLike[]
  saves    CommunitySave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityComment {
  id      String @id @default(uuid())
  postId  String
  userId  String
  content String

  post CommunityPost @relation(fields: [postId], references: [id])
  user User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model CommunityLike {
  id     String @id @default(uuid())
  postId String
  userId String

  post CommunityPost @relation(fields: [postId], references: [id])
  user User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model CommunitySave {
  id     String @id @default(uuid())
  postId String
  userId String

  post CommunityPost @relation(fields: [postId], references: [id])
  user User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Mission {
  id          String        @id @default(uuid())
  title       String
  description String?
  type        MissionType
  action      MissionAction

  target          Int
  rewardXp        Int @default(0)
  rewardCoins     Int @default(0)
  rewardFood      Int @default(0)
  rewardEnergy    Int @default(0)
  rewardHappiness Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progresses UserMission[]
}

model UserMission {
  id        String @id @default(uuid())
  userId    String
  missionId String

  progress  Int     @default(0)
  completed Boolean @default(false)
  claimed   Boolean @default(false)

  periodkey   String?
  completedAt DateTime?
  claimedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  mission Mission @relation(fields: [missionId], references: [id])

  @@unique([userId, missionId, periodkey])
}

model UserLearningProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  level           String  @default("A1")
  goal            String?
  dailyWordTarget Int     @default(10)
  user            User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WordTopic {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  color       String?

  words      Word[]
  poolItems  WeeklyTopicPoolItem[]
  dailyPlans UserDailyVocabularyPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWordProgress {
  id     String @id @default(uuid())
  userId String
  wordId String

