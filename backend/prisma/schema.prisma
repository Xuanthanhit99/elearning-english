model UserSkillLevel {
  id          String          @id @default(uuid())
  userId      String
  placementId String?
  skill       LearningSkill
  level       CefrLevel
  score       Float?
  source      PlacementMethod
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  placement UserPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)

