  SEED
  GEMINI
  ADMIN
}

enum PlacementProcessingStatus {
  WAITING
  PROCESSING
  COMPLETED
  FAILED
}

enum PlacementProcessingItemStatus {
  WAITING
  PROCESSING
  COMPLETED
  SKIPPED
  FAILED
}

enum PlacementProcessingStep {
  ANSWER_ANALYSIS
  SKILL_EVALUATION
  LEARNING_PATH
  QUALITY_CHECK
}

model PlacementProcessingJob {
  id                        String                    @id @default(uuid())
  testId                    String                    @unique
  userId                    String
  status                    PlacementProcessingStatus @default(WAITING)
  currentStep               PlacementProcessingStep?
  progress                  Int                       @default(0)
  estimatedRemainingSeconds Int                       @default(90)
  errorMessage              String?
  nextUrl                   String?
  startedAt                 DateTime?
  completedAt               DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  test     PlacementTest                   @relation(fields: [testId], references: [id], onDelete: Cascade)
  user     User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps    PlacementProcessingStepState[]
  skills   PlacementProcessingSkillState[]
  logs     PlacementProcessingLog[]
  insights PlacementProcessingInsight[]

  @@index([userId])
  @@index([status])
}

model PlacementProcessingStepState {
  id          String                        @id @default(uuid())
  jobId       String
  step        PlacementProcessingStep
  title       String
  status      PlacementProcessingItemStatus @default(WAITING)
  progress    Int                           @default(0)
  order       Int
  startedAt   DateTime?
  completedAt DateTime?

  job PlacementProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, step])
  @@index([jobId, order])
}

model PlacementProcessingSkillState {
  id       String                        @id @default(uuid())
  jobId    String
  skill    LearningSkill
  status   PlacementProcessingItemStatus @default(WAITING)
  progress Int                           @default(0)
  score    Float?
  level    CefrLevel?
  message  String?
  order    Int

  job PlacementProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, skill])
  @@index([jobId, order])
}

model PlacementProcessingLog {
  id        String                        @id @default(uuid())
  jobId     String
  message   String
  status    PlacementProcessingItemStatus
  createdAt DateTime                      @default(now())

  job PlacementProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model PlacementProcessingInsight {
  id        String   @id @default(uuid())
  jobId     String
  content   String
  order     Int
  createdAt DateTime @default(now())

  job PlacementProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, order])
}

enum PlacementResultStatus {
  DRAFT
  READY
  FAILED
}

model PlacementResult {
  id                String                @id @default(uuid())
  testId            String                @unique
  userId            String
  status            PlacementResultStatus @default(DRAFT)
  overallScore      Float
  overallLevel      CefrLevel
  percentile        Int?
  confidence        Int?
  summary           String?
  strengths         Json?
  improvements      Json?
  projectedLevel    CefrLevel?
  projectedWeeksMin Int?
  projectedWeeksMax Int?
  processedSeconds  Int?
  certificateCode   String?               @unique
  certificateUrl    String?
  generatedAt       DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  test       PlacementTest                @relation(fields: [testId], references: [id], onDelete: Cascade)
  user       User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills     PlacementResultSkill[]
  phases     PlacementLearningPathPhase[]
  priorities PlacementLearningPriority[]
  courses    PlacementRecommendedCourse[]

  @@index([userId, generatedAt])
}

model PlacementResultSkill {
  id           String                        @id @default(uuid())
  resultId     String
  skill        LearningSkill
  score        Float
  level        CefrLevel?
  status       PlacementProcessingItemStatus
  rating       Float?
  label        String?
  strengths    Json?
  improvements Json?
  feedback     String?

  result PlacementResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, skill])
}

model PlacementLearningPathPhase {
  id          String     @id @default(uuid())
  resultId    String
  phase       Int
  title       String
  targetLevel CefrLevel?
  weeksMin    Int
  weeksMax    Int
  description String
  objectives  Json
  progress    Int        @default(0)

  result PlacementResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, phase])
}

model PlacementLearningPriority {
  id       String        @id @default(uuid())
  resultId String
  skill    LearningSkill
  priority Int
  reason   String

  result PlacementResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, priority])
}

model PlacementRecommendedCourse {
  id          String  @id @default(uuid())
  resultId    String
  courseId    String?
  title       String
  slug        String?
  thumbnail   String?
  rating      Float?
  reviews     Int?
  lessonCount Int?
  reason      String
  order       Int

  result PlacementResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([resultId, order])
}
