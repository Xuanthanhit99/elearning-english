enum PlacementMethod {
  TEST
  CERTIFICATE
  MANUAL
}

enum PlacementStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LearningSkill {
  VOCABULARY
  GRAMMAR
  LISTENING
  READING
  SPEAKING
  WRITING
}

enum LanguageCertificateType {
  IELTS
  TOEIC
  TOEFL_IBT
  CAMBRIDGE
  CEFR
  OTHER
}

enum CertificateVerificationStatus {
  PENDING
  PROCESSING
  VERIFIED
  REJECTED
  NEEDS_REVIEW
}

model UserPlacement {
  id           String          @id @default(uuid())
  userId       String          @unique
  method       PlacementMethod
  status       PlacementStatus @default(NOT_STARTED)
  overallLevel CefrLevel?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
